# --- LLM (streaming chat + onboarding agents) ---
# Azure AI / Anthropic-compatible URL and key; deployment name → AZURE_LLM_NAME
# See ai/llms.py and ai/agents/sql/agent.py
AZURE_LLM_ENDPOINT=
AZURE_LLM_API_KEY=
AZURE_LLM_NAME=
AZURE_LLM_API_VERSION=

# Supabase (Dashboard → Project Settings → API)
# URL contains the project ref: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# anon / public key — safe for client-side use with RLS
SUPABASE_KEY=your-anon-public-key
# service_role — server-only; never expose to browsers
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Data plane (blob layout for Parquet; Azure Functions / Container Apps) ---
# Optional until sync + SQL agent paths are live (checklist §5–§6).
AZURE_STORAGE_ACCOUNT_URL=https://youraccount.blob.core.windows.net
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=raw
BLOB_CONTAINER_NAME=raw
USER_DATA_BLOB_PREFIX=users

# --- SQL agent backend ---
SQL_AGENT_BACKEND=duckdb

# --- Authentication ---
# Optional: force signup email-confirm links to this frontend URL.
# If empty, Supabase Auth project/site URL settings are used.
AUTH_SIGNUP_EMAIL_REDIRECT_TO=

# --- Guided onboarding (OAuth redirect must match provider app + this API URL) ---
API_PUBLIC_BASE_URL=http://127.0.0.1:8000
ONBOARDING_FRONTEND_REDIRECT=http://localhost:5173/data/connect
# Optional: enable Docker check/discover/read in onboarding tools (local dev).
# Required for a real run_sync test read (you should see Docker containers run).
ONBOARDING_DOCKER_ENABLED=1
# Execution mode:
# - local: execute docker CLI on the backend host
# - azure_job: trigger a dedicated Azure Container Apps Job and wait for completion
ONBOARDING_DOCKER_EXECUTION_MODE=local

# --- Azure Container Apps Job (Sync V2: single ACA Job + File Share) ---
# All connectors run as official Airbyte Docker images on a single ACA Job
# with image override. One job handles both onboarding (check/discover/probe)
# and scheduled syncs.
# Required when ONBOARDING_DOCKER_EXECUTION_MODE=azure_job or for scheduled syncs.
ACA_SUBSCRIPTION_ID=
ACA_RESOURCE_GROUP=
ACA_JOB_NAME=
ACA_JOB_CONTAINER_NAME=connector
# Azure File Share connection (config/output exchange between caller and ACA Job)
AZURE_FILE_SHARE_CONN_STR=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_FILE_SHARE_NAME=connector-data-v2
# Sync uploader image in ACR (reads JSONL from File Share → Parquet → Blob)
SYNC_UPLOADER_IMAGE=acrpurelybiv2devci.azurecr.io/sync-uploader:latest

# --- Ops ---
LOG_LEVEL=INFO
# Comma-separated extra CORS origins for deployed frontends
CORS_EXTRA_ORIGINS=
